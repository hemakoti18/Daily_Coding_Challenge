
# create database
create database clg_std_mngmt_system;
# use database
use clg_std_mngmt_system ;
# create tables
# 1.student table
CREATE TABLE students ( 
    student_id INT PRIMARY KEY, 
    student_name VARCHAR(50), 
    gender VARCHAR(10), 
    city VARCHAR(50), 
    join_year INT 
); 
