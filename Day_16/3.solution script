
# create database customer segmentation
create database `customer segmentation` ;
# use database
use `customer segmentation` ;
# create tables
# 1.customers
CREATE TABLE customers ( 
    customer_id INT, 
    customer_name VARCHAR(50), 
    city VARCHAR(50), 
    age INT, 
    total_spent DECIMAL(10,2), 
    number_of_orders INT 
); 
# display table structure
describe customers ;

# add primary key and auto_increment
alter table customers
modify customer_id int primary key auto_increment,
modify customer_name varchar(50) not null,
modify city varchar(50) not null,
modify age int check(age>0) ;

